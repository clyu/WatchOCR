<?xml version="1.0" encoding="utf-8"?>
<!-- Backup/transfer rules for Android 12+ (API 31+). The settings DataStore
     holds the Gemini API key, so it is excluded from both cloud backups and
     device-to-device transfers. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/watchocr_settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/watchocr_settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
